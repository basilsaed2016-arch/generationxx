# ============================================
# GenerationX Roleplay — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# ----- Database -----
# SQLite (default — works locally and on Vercel with Turso/external DB)
DATABASE_URL="file:./db/custom.db"

# For PostgreSQL (recommended for Vercel production):
# DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# ----- Discord OAuth2 -----
# Get these from: https://discord.com/developers/applications
# Create a new application → OAuth2 tab → copy Client ID and Client Secret
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ----- Discord Server (Guild) -----
# The Discord server ID where citizen verification will be checked.
# Right-click your server name in Discord → "Copy ID" (enable Developer Mode in Discord settings).
DISCORD_GUILD_ID=""

# The role ID that marks a user as a "Verified Citizen".
# Right-click the role in your server settings → "Copy ID".
DISCORD_VERIFIED_ROLE_ID=""

# ----- Admin -----
# The Discord user ID of the server owner / admin.
# Right-click your own username in Discord → "Copy ID".
# This user will have access to the Admin Dashboard.
ADMIN_DISCORD_ID=""

# ----- Discord Bot Token (optional but recommended) -----
# To check if a user has the "Verified Citizen" role, we need to read
# their guild member data — which requires a bot token with the
# "Server Members Intent" enabled.
#
# Without this, verification falls back to guild-membership-only
# (anyone who joined the server is considered verified).
#
# Create a bot in the same Discord application:
#   1. Go to your application → "Bot" tab → "Add Bot"
#   2. Copy the token
#   3. Enable "Server Members Intent"
#   4. Invite the bot to your server
DISCORD_BOT_TOKEN=""

# ----- App URL (optional — auto-detected) -----
# Set this explicitly if deploying behind a proxy or custom domain.
# Examples:
#   NEXT_PUBLIC_APP_URL="http://localhost:3000"
#   NEXT_PUBLIC_APP_URL="https://generationx.vercel.app"
# NEXT_PUBLIC_APP_URL=""

# ----- Discord Invite -----
# The invite link shown on the website.
NEXT_PUBLIC_DISCORD_INVITE="https://discord.gg/gx-rp"
